---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { site } from "../data/site";

const features = [
  {
    title: "Capture without friction",
    text: "Grab exactly what you need and move into editing right away."
  },
  {
    title: "Make the point obvious",
    text: "Use arrows, text, highlights, blur, and pixelation to guide attention in seconds."
  },
  {
    title: "Share a cleaner result",
    text: "Turn a raw capture into something polished enough for feedback, support, or documentation."
  }
];

const useCases = [
  {
    title: "Bug reports",
    text: "Show the exact issue instead of writing a long explanation around it."
  },
  {
    title: "Product feedback",
    text: "Point at layout changes, small regressions, or details that need another pass."
  },
  {
    title: "Documentation",
    text: "Create visuals that are easier to read in guides, release notes, and onboarding steps."
  }
];
---

<BaseLayout>
  <Header />

  <main class="page">
    <section class="container hero hero-stack">
      <div class="hero-copy">
        <p class="eyebrow">Made For macOS</p>
        <h1>Better screenshots, with less effort.</h1>
        <p class="lead">
          VivyShot helps you capture your screen, mark up what matters, and share a result that looks clear and intentional.
        </p>

        <div class="hero-actions">
          <a class="button" href="/support">Get Support</a>
          <a class="button-secondary" href={site.github} target="_blank" rel="noreferrer">Follow Development</a>
        </div>
      </div>

      <div class="showcase">
        <div class="showcase-frame" aria-hidden="true">
          <div class="showcase-canvas">
            <div class="showcase-shot">
              <div class="annotation-box"></div>
              <div class="annotation-arrow"></div>
              <div class="annotation-caption">Point people to the important part</div>
            </div>
          </div>
        </div>

        <div class="hero-meta hero-meta-row">
          <span>Screenshots</span>
          <span>Annotations</span>
          <span>Fast sharing</span>
        </div>
      </div>
    </section>

    <section class="container section intro-strip">
      <p>
        Capture what matters. Add a note, an arrow, a highlight, or a blur. Send something people understand immediately.
      </p>
    </section>

    <section class="container section section-surface">
      <div class="section-heading-wrap">
        <h2 class="section-heading">Everything needed for a clear screenshot.</h2>
        <p class="section-subtitle">
          VivyShot is for people who want to capture something, explain it quickly, and move on.
        </p>
      </div>

      <div class="feature-panels">
        {features.map((feature) => (
          <article class="feature-panel">
            <h3>{feature.title}</h3>
            <p>{feature.text}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="container section editorial apple-split">
      <div class="editorial-copy">
        <p class="eyebrow">Why People Use It</p>
        <h2>Useful for support, product feedback, docs, and everyday sharing.</h2>
        <p>
          A good screenshot should not need extra explanation. VivyShot helps you direct attention, add context, and remove distractions before you send it.
        </p>
        <p>
          It fits the everyday moments where speed matters: reporting a bug, sharing progress, giving feedback, or saving a visual note for later.
        </p>
      </div>

      <div class="editorial-aside">
        <div class="editorial-note">
          Clear screenshots save time for both the person sending them and the person reading them.
        </div>
      </div>
    </section>

    <section class="container section section-surface">
      <div class="section-heading-wrap">
        <h2 class="section-heading">Common ways people use it.</h2>
        <p class="section-subtitle">
          The app should feel useful long before anyone cares how it is built.
        </p>
      </div>

      <div class="use-case-grid">
        {useCases.map((item) => (
          <article class="use-case">
            <h3>{item.title}</h3>
            <p>{item.text}</p>
          </article>
        ))}
      </div>

      <div class="cta">
        <div>
          <h2>Need help or legal information?</h2>
          <p>
            Support, privacy, and terms pages are already in place and ready to expand as the app gets closer to release.
          </p>
        </div>
        <a class="button" href="/support">Open support</a>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

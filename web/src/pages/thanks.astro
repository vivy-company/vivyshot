---
import BaseLayout from "../layouts/BaseLayout.astro";
import { SITE } from "../lib/site";
---

<BaseLayout
  title="Thank You - VivyShot"
  description="Thank you for following VivyShot."
  canonicalPath="/thanks"
>
  <main class="px-4 py-12 sm:px-6 sm:py-16">
    <div class="mx-auto max-w-2xl">
      <article class="rounded-[2rem] border border-slate-900/8 bg-white/90 p-8 shadow-[0_22px_60px_rgba(15,23,42,0.08)] backdrop-blur dark:border-white/10 dark:bg-[#121214] dark:shadow-none">
        <header class="text-center">
          <div class="relative mx-auto mb-4 w-fit">
            <img src="/logo.png" alt="VivyShot" width="88" height="88" class="size-[5.5rem] rounded-[1.4rem]" />
            <div class="absolute -bottom-1 -right-1 grid size-8 place-items-center rounded-full bg-emerald-500 text-white">✓</div>
          </div>
          <h1 class="text-5xl font-semibold tracking-tight text-slate-950 dark:text-slate-100">Thank You!</h1>
          <p class="mt-3 text-lg text-slate-600 dark:text-slate-300">Thanks for checking out VivyShot.</p>
        </header>

        <section class="mt-8 grid gap-4">
          <div class="grid gap-4 border-b border-slate-900/8 py-4 dark:border-white/10 sm:grid-cols-[3rem_1fr]">
            <div class="grid size-12 place-items-center rounded-2xl bg-slate-100 dark:bg-white/8">⌁</div>
            <div>
              <h2 class="text-xl font-semibold text-slate-950 dark:text-slate-100">Follow the project</h2>
              <p class="mt-2 text-slate-600 dark:text-slate-300">The best place to track product direction right now is the repository and surrounding project updates.</p>
            </div>
          </div>
          <div class="grid gap-4 py-4 sm:grid-cols-[3rem_1fr]">
            <div class="grid size-12 place-items-center rounded-2xl bg-slate-100 dark:bg-white/8">☁</div>
            <div>
              <h2 class="text-xl font-semibold text-slate-950 dark:text-slate-100">Architecture first</h2>
              <p class="mt-2 text-slate-600 dark:text-slate-300">VivyShot is still greenfield, so the current focus is getting the Rust-first core and macOS surface aligned properly.</p>
            </div>
          </div>
        </section>

        <div class="mt-8 flex justify-center">
          <a class="inline-flex min-h-12 items-center justify-center rounded-full border border-slate-900/10 bg-white px-5 py-3 text-sm font-semibold text-slate-950 dark:border-white/10 dark:bg-white/5 dark:text-slate-100" href={SITE.githubUrl} target="_blank" rel="noopener noreferrer">
            View GitHub
          </a>
        </div>

        <p class="mt-5 text-center text-sm text-slate-500 dark:text-slate-400">
          Need help? Contact us at <a href="mailto:vivyshot@vivy.company" class="text-slate-950 dark:text-white">vivyshot@vivy.company</a>
        </p>
        <p class="mt-6 text-center">
          <a href="/" class="text-sm font-medium text-slate-950 hover:underline dark:text-white">← Back to Home</a>
        </p>
      </article>
    </div>
  </main>
</BaseLayout>
